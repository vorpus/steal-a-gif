{
  "name": "steal-a-gif",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Recover a clean, downloadable GIF from a screen recording of a hard-to-download animation.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@imgly/background-removal": "^1.5.8",
    "gifenc": "^1.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
